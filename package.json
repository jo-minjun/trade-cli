{
  "name": "trade-cli",
  "version": "0.1.0",
  "description": "A lightweight trading CLI tool designed to work with OpenClaw AI agents",
  "type": "module",
  "bin": {
    "trade": "./trade"
  },
  "main": "dist/index.js",
  "scripts": {
    "dev": "node --import tsx src/index.ts",
    "build": "tsdown",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "license": "MIT",
  "packageManager": "pnpm@10.30.3",
  "dependencies": {
    "better-sqlite3": "^12.6.2",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "yaml": "^2.8.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.3.5",
    "tsdown": "^0.21.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}